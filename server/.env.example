# Copy to .env and fill in your SMTP credentials before deploying

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@amazinggracehl.org
SMTP_PASS=your-app-password-here
ALLOWED_ORIGIN=https://amazinggracehl.org
PORT=3000

# Optional: set a random secret to enable the /test-email smoke-test endpoint.
# Leave blank (or unset) to disable /test-email entirely in production.
# TEST_EMAIL_TOKEN=replace-with-a-strong-random-secret

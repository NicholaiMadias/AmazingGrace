{
  "manifest_version": 3,
  "name": "Nexus Match-Maker",
  "version": "1.0.0",
  "description": "The Seven-Star Match-3 Decryption Engine featuring gem atlases, virtue fragments, and Nexus puzzle logic.",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/",
    "http://*/"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "svg/gems-atlas.svg",
        "svg/master-atlas.svg",
        "assets/*.png",
        "engine/*.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
